# Example environment file for the chatbot backend
# Copy this to `.env` in the same folder and replace placeholder values with your real keys.

# OpenAI API key (preferred if you're using OpenAI)
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY

# OR Google Gemini API key (if you use Gemini)
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY

# JWT secret for signing tokens (replace with a random secret in production)
JWT_SECRET=your_jwt_secret_key

# Database settings (optional if you use defaults)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_NAME=teacher_notes
DB_PORT=3306

# Other settings
PORT=3000
